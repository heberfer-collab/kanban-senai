generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  avatarUrl String?
  tasks     Task[]
  tags      Tag[]
  columns   Column[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Tag {
  id        String   @id @default(uuid())
  name      String
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  tasks     TaskTag[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, userId])
}

model Task {
  id          String   @id @default(uuid())
  title       String
  description String?
  status      String   @default("TODO") // TODO, IN_PROGRESS, DONE
  dueDate     DateTime?
  priority    String   @default("MEDIUM") // URGENT, MEDIUM, LOW
  category    String   @default("TRABALHO") // TRABALHO, PESSOAL, ESTUDOS, CASA
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  tags        TaskTag[]
  isPublic    Boolean  @default(false)
  shareToken  String?  @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TaskTag {
  taskId String
  tagId  String
  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tag    Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([taskId, tagId])
}

model Column {
  id          String   @id @default(uuid())
  title       String
  colorBorder String   @default("border-slate-300 dark:border-slate-600")
  bgColor     String   @default("bg-slate-100 dark:bg-slate-800/40")
  order       Int      @default(0)
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([title, userId])
}
